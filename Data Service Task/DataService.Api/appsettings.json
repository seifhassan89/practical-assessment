{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "Console": {
      "Enabled": true,
      "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
    },
    "File": {
      "Enabled": true,
      "Path": "logs/dataservice-.log",
      "RollingInterval": "Day",
      "UseCompactJsonFormatter": true
    },
    "Enrich": {
      "FromLogContext": true,
      "WithMachineName": true,
      "WithThreadId": true
    }
  },
  "DataService": {
    "File": {
      "FilePath": "Data/sample.txt"
    },
    "Cache": {
      "Key": "data-service-lines",
      "DurationInSeconds": 60
    },
    "ReturnedDataLogging": {
      "EnableDetailedLineLogging": true
    }
  },
  "Cors": {
    "AllowedOrigins": ["https://your-app.example.com"],
    "AllowedMethods": [],
    "AllowedHeaders": []
  }
}

